# ── signal-vault-web environment variables ────────────────────────────────────
# Copy this file to .env.local and fill in values for local development.
# Never commit .env.local or any file containing real secrets.

# Backend API base URL.
# Leave empty to use relative paths (proxied by Next.js rewrites → localhost:8080).
# Set to the full backend URL when the frontend is NOT on the same host as the API
# (e.g. a separate Vercel deploy pointing at a VPS).
NEXT_PUBLIC_API_BASE_URL=

# WebSocket endpoint.
# /ws uses the Next.js rewrite proxy (recommended for local dev + ngrok).
# For production with a dedicated domain, set to: https://api.yourdomain.com/ws
NEXT_PUBLIC_WS_URL=/ws
