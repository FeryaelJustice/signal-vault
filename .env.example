# ── SignalVault backend environment variables ─────────────────────────────────
# Used by docker-compose.yml. Copy to .env and fill in for local overrides.
# In production, set these variables in your deployment platform (Railway, Fly, etc.)
# and NEVER commit the real values.

# PostgreSQL connection (matches the postgres service in docker-compose.yml)
POSTGRES_DB=signalvault
POSTGRES_USER=signalvault
POSTGRES_PASSWORD=signalvault

# Spring Boot datasource (used by signalvault-api service)
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/signalvault
SPRING_DATASOURCE_USERNAME=signalvault
SPRING_DATASOURCE_PASSWORD=signalvault

# JWT — MUST be changed in production (256-bit random secret)
# Generate with: openssl rand -hex 32
APP_JWT_SECRET=dev-only-change-me-please-use-a-long-random-256-bit-secret-value
APP_JWT_ACCESS_TTL=900       # seconds (15 min)
APP_JWT_REFRESH_TTL=604800   # seconds (7 days)

# CORS — comma-separated list of allowed frontend origins
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
